# =============================================================================
# Quicklook Server — Environment Variables
# =============================================================================
# Copy to .env and fill in values. For production (e.g. Cloud Run), set these
# in the Cloud Run service (Console or gcloud) or via Secret Manager.
# =============================================================================

# --- Required (all environments) ---
# MongoDB connection string for sessions, projects, users, chunks (when CHUNK_STORAGE=mongodb)
QUICKLOOK_DB=mongodb://user:pass@host:27017/quicklook?retryWrites=true&w=majority

# JWT secret for auth (register/login). Use a strong random value in production.
JWT_SECRET=your-secret-change-in-production

# --- Server ---
PORT=3080

# Optional: serve over HTTPS (e.g. for https://localhost:3080 so the SDK loads on HTTPS pages).
# Set USE_HTTPS=1 and paths to PEM key and cert. For localhost, use mkcert (e.g. mkcert -key-file key.pem -cert-file cert.pem localhost) or your own self-signed cert.
# USE_HTTPS=1
# SSL_KEY_PATH=./key.pem
# SSL_CERT_PATH=./cert.pem

# --- Chunk storage ---
# 'mongodb' (default) or 'gcs'. Use gcs for production scale.
CHUNK_STORAGE=mongodb

# --- GCS (required when CHUNK_STORAGE=gcs) ---
# Bucket name (e.g. quicklook-chunks). Must exist or be auto-created (see GCS_KEY_FILE).
GCS_BUCKET=quicklook-chunks
# GCP project ID
GCP_PROJECT_ID=your-gcp-project-id
# Path to service account JSON key file. On Cloud Run you can omit this if the
# service account has Storage Object Admin on the bucket (uses default credentials).
GCS_KEY_FILE=/path/to/service-account-key.json

# Optional: bucket region (default us-central1). Used when auto-creating the bucket.
# GCS_BUCKET_LOCATION=us-central1

# GCS pricing for cost calculation job (USD per GB/month)
GCS_STORAGE_COST_PER_GB=0.020

# --- Optional ---
# API key for read endpoints (GET /sessions, etc.). If unset, reads are allowed.
# QUICKLOOK_API_KEY=

# Optional: set to production for retention job behavior (e.g. skip dry-run).
# NODE_ENV=production

# --- Analytics (Phase 2/3: root cause, session summary) ---
# Base URL of quicklook-analytics service (e.g. https://quicklook-analytics-xxx.run.app).
# If unset, ensure-summary and ensure-root-cause endpoints return 503.
# QUICKLOOK_ANALYTICS_URL=https://quicklook-analytics-xxxx.run.app
# Local dev with HTTPS + self-signed cert: set NODE_TLS_REJECT_UNAUTHORIZED=0 so fetch() can call analytics.

# --- Billing (Stripe) ---
# PAYMENT_PROVIDER=stripe
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# For checkout redirects (e.g. http://localhost:5173).
# APP_URL=http://localhost:5173
# Plan config (including Stripe price IDs) is stored in MongoDB. Run: npm run seed:plan-config
# (with QUICKLOOK_DB and optionally STRIPE_SECRET_KEY) to upsert plans and create Stripe product/prices.

# --- Email (AWS SES) ---
# AWS region where SES is (e.g. us-east-1). Required for sending email.
# AWS_REGION=us-east-1
# Default From address (verified domain identity, e.g. noreply@quicklook.io).
# SES_FROM=noreply@quicklook.io
# Base URL for app (verification and reset links in emails). No trailing slash.
# FRONTEND_URL=https://quicklook.io
# For scripts/sendSesTestEmail.js: recipient for the test email.
# SES_TEST_TO=your-email@example.com
# AWS credentials (or use default credential chain / IAM role on Cloud Run).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
