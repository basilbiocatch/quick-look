# MongoDB (Quicklook DB)
QUICKLOOK_DB=mongodb://user:pass@host:27017/quicklook?retryWrites=true&w=majority

# Server
PORT=3080

# JWT secret for auth (register/login). Required for production.
JWT_SECRET=your-secret-change-in-production

# Optional: API key for read endpoints (GET /sessions, etc.). If not set, reads are allowed (e.g. localhost dev).
QUICKLOOK_API_KEY=
