# Copy to .env and fill in. Use the same QUICKLOOK_DB as quicklook-server for local dev.
QUICKLOOK_DB=mongodb://localhost:27017/quicklook

# Phase 1: only QUICKLOOK_DB is required. GEMINI_API_KEY is not used until Phase 2+.
# GCP_PROJECT_ID=quick-look-488819
# GEMINI_API_KEY=   # Required from Phase 2 onward (summaries, reports, root cause)
# GEMINI_MODEL=gemini-2.0-flash   # Optional; default 2.0-flash. If 404, try gemini-2.5-flash
# GCS_BUCKET=       # Same as quicklook-server when sessions use storageType=gcs (required to read events from GCS)
