# Quicklook API: leave empty in dev so the app uses relative /api (proxied by Vite). Set in production to your server URL.
# When the backend runs with HTTPS (USE_HTTPS=1), set VITE_PROXY_TARGET=https://localhost:3080 so the proxy connects via HTTPS; keep VITE_API_BASE_URL empty so the browser does not hit the backend directly (avoids ERR_CERT).
VITE_API_BASE_URL=

# Optional: proxy target for Vite dev server (defaults to http://localhost:3080). Set to https://localhost:3080 when backend uses HTTPS.
# VITE_PROXY_TARGET=https://localhost:3080

# Optional: API key for read endpoints (if server has QUICKLOOK_API_KEY set)
VITE_QUICKLOOK_API_KEY=
